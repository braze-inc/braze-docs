# Confluence API credentials for scripts/fetch_confluence_pages.py
# Copy this file to .env and fill in your values. Never commit .env.

# Base URL of your Confluence (include /wiki)
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki

# Your Atlassian account email
CONFLUENCE_EMAIL=you@company.com

# API token (create at https://id.atlassian.com/manage-profile/security/api-tokens)
CONFLUENCE_API_TOKEN=your-api-token

# Option A: Whole space
CONFLUENCE_SPACE_KEY=TAM

# Option B: Subset — parent page and its descendants only (use parent URL or page ID)
# CONFLUENCE_PARENT_PAGE_URL=https://confluence.atl.braze.com/wiki/pages/viewpage.action?pageId=123456789
# CONFLUENCE_PARENT_PAGE_ID=123456789
